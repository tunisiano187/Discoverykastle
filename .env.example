# ============================================================
# Discoverykastle — Environment Configuration Template
# Copy to .env and fill in values before starting.
# NEVER commit .env to version control.
# ============================================================

# ---- Required: Admin Account ---------------------------------
DKASTLE_ADMIN_USERNAME=admin
DKASTLE_ADMIN_PASSWORD=ChangeMe!PleaseChangeThisBeforeFirstUse

# ---- Required: Security Keys ---------------------------------
# Generate with: openssl rand -hex 32
DKASTLE_SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_STRING

# Generate with: openssl rand -base64 32
# This key encrypts the credential vault — keep it safe!
DKASTLE_VAULT_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

# ---- Required: Scan Authorization ----------------------------
# Comma-separated CIDR ranges you are authorized to scan.
# NO scan will proceed outside these ranges.
# Example: 192.168.0.0/16,10.0.0.0/8
DKASTLE_AUTHORIZED_CIDRS=

# Public IP scan protection (default: true)
# When true, scanning a publicly-routable IP or CIDR requires an explicit
# AuthorizationRequest approved by a human via the dashboard or API.
# RFC-1918 / private ranges are always scanned without extra approval.
# Set to false only in fully-controlled lab environments.
DKASTLE_REQUIRE_PUBLIC_SCAN_AUTHORIZATION=true

# ---- Server --------------------------------------------------
DKASTLE_HOST=0.0.0.0
DKASTLE_PORT=8443
DKASTLE_LOG_LEVEL=INFO

# Maximum recursive discovery depth (default: 2)
DKASTLE_MAX_SCAN_DEPTH=2

# Default task timeout in seconds (default: 3600 = 1 hour)
DKASTLE_TASK_TIMEOUT=3600

# ---- TLS Certificates ----------------------------------------
# Leave empty to use auto-generated self-signed cert (dev only)
DKASTLE_TLS_CERT=
DKASTLE_TLS_KEY=

# ---- Database ------------------------------------------------
POSTGRES_DB=discoverykastle
POSTGRES_USER=dkastle
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Redis ---------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---- CVE Database --------------------------------------------
# Set to false for airgapped deployments
DKASTLE_NVD_API_ENABLED=true
# Optional: NVD API key for higher rate limits (https://nvd.nist.gov/developers/request-an-api-key)
DKASTLE_NVD_API_KEY=

# ---- Notifications (optional) --------------------------------
DKASTLE_SMTP_HOST=
DKASTLE_SMTP_PORT=587
DKASTLE_SMTP_USER=
DKASTLE_SMTP_PASSWORD=
DKASTLE_ALERT_EMAIL=

DKASTLE_SLACK_WEBHOOK=

# ---- Logging -------------------------------------------------
# Minimum log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
DKASTLE_LOG_LEVEL=INFO

# Path to the rotating JSON log file (20 MB × 10 files).
# Set to empty string to disable file logging (not recommended).
DKASTLE_LOG_FILE=discoverykastle.log

# Graylog GELF/UDP — leave empty to disable.
# Requires: pip install 'discoverykastle-server[graylog]'
# Every log record is forwarded with all structured extra= fields,
# making it possible to filter by action, module, host_ip, cve_id, etc.
DKASTLE_GRAYLOG_HOST=
DKASTLE_GRAYLOG_PORT=12201
DKASTLE_GRAYLOG_FACILITY=discoverykastle

# ---- Browser Web Push notifications (disabled by default) ---
# Sends push notifications to subscribed browsers when alerts fire.
# No external service needed — uses the VAPID standard.
# Requires: pip install 'discoverykastle-server[webpush]'
# Generate VAPID keys via the setup wizard (GET /setup/generate-vapid).
DKASTLE_WEBPUSH_ENABLED=false
DKASTLE_VAPID_EMAIL=admin@example.com
DKASTLE_VAPID_PUBLIC_KEY=
DKASTLE_VAPID_PRIVATE_KEY=
# Only alerts at or above this severity trigger a push: critical|high|medium|low|info
DKASTLE_WEBPUSH_MIN_SEVERITY=high
# File to store browser subscriptions (JSON, relative to working dir)
DKASTLE_WEBPUSH_SUB_FILE=webpush_subscriptions.json

# ---- AI Enrichment (disabled by default) ---------------------
# Enable ONLY if you need contextual CVE triage.
# AI is NOT used for anything that can be solved with rules.
# Use case: assessing whether a CVE's exploitation prerequisites
# are actually met on a specific host (requires reading CVE descriptions).
DKASTLE_AI_ENABLED=false

# Backend: auto | ollama | anthropic
#   auto      → use Ollama if reachable, otherwise fall back to Anthropic
#   ollama    → force local Ollama (no API key, no extra pip dep)
#   anthropic → force Anthropic cloud (requires API key + pip dep below)
DKASTLE_AI_BACKEND=auto

# ---- Ollama (local, recommended for privacy / air-gapped) ----
# Install: https://ollama.com/download
# Start:   ollama serve
# Models:  ollama pull llama3.2        # fast, good reasoning (default)
#          ollama pull mistral          # alternative
#          ollama pull phi3:mini        # lightweight, CPU-only
#          ollama pull deepseek-r1:7b   # strong at code/security analysis
# No extra pip dependency — uses httpx which is already installed.
DKASTLE_OLLAMA_URL=http://localhost:11434
DKASTLE_OLLAMA_MODEL=llama3.2

# ---- Anthropic cloud (optional, if Ollama is not available) --
# Requires: pip install 'discoverykastle-server[ai]'
# Models:   claude-haiku-4-5-20251001  (fast, cheap — default)
#           claude-sonnet-4-6           (more accurate, higher cost)
DKASTLE_ANTHROPIC_API_KEY=
DKASTLE_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---- DNS Enrichment (enabled by default) ---------------------
# Performs reverse PTR lookups for discovered hosts and SOA queries to
# identify the DNS domain that owns each subnet.
# Set to false to disable all DNS enrichment.
DKASTLE_DNS_RESOLVE_ENABLED=true
# Optional: IP of a specific DNS server to query (leave blank for system resolver)
DKASTLE_DNS_SERVER=
# Timeout in seconds for each DNS query (default: 3.0)
DKASTLE_DNS_TIMEOUT=3.0

# ---- Active Directory / LDAP (disabled by default) -----------
# Queries the domain controller for computer account details when hosts
# are detected inside a Windows AD domain.
# Requires read-only LDAP credentials.
DKASTLE_LDAP_ENABLED=false
DKASTLE_LDAP_SERVER=                    # e.g. ldap://dc.example.com
DKASTLE_LDAP_BIND_DN=                   # e.g. CN=readonly,DC=example,DC=com
DKASTLE_LDAP_BIND_PASSWORD=
DKASTLE_LDAP_BASE_DN=                   # e.g. DC=example,DC=com

# ---- Puppet Integration (disabled by default) ----------------
# Imports node facts from PuppetDB (OS, IPs, packages, environment).
# PuppetDB API: https://www.puppet.com/docs/puppetdb/latest/api/
DKASTLE_PUPPETDB_ENABLED=false
DKASTLE_PUPPETDB_URL=                   # e.g. https://puppet.example.com:8081
DKASTLE_PUPPETDB_TOKEN=                 # PE RBAC token or bearer token
# How often to sync with PuppetDB (seconds, default: 3600)
DKASTLE_PUPPETDB_SYNC_INTERVAL=3600

# ---- Ansible Integration (disabled by default) ---------------
# Two collection modes (one or both can be set):
#   1. AWX / Ansible Tower REST API
#   2. Local fact cache directory (jsonfile or yaml cache plugin)
DKASTLE_ANSIBLE_ENABLED=false
DKASTLE_ANSIBLE_AWX_URL=                # e.g. https://awx.example.com
DKASTLE_ANSIBLE_AWX_TOKEN=             # AWX OAuth2 bearer token
DKASTLE_ANSIBLE_FACT_CACHE_DIR=        # e.g. /var/cache/ansible/facts
# How often to sync with Ansible (seconds, default: 3600)
DKASTLE_ANSIBLE_SYNC_INTERVAL=3600

# ---- Agent (set on agent containers, not server) -------------
# DKASTLE_SERVER_URL=wss://your-server:8443
# DKASTLE_ENROLL_TOKEN=<generated-from-dashboard>
